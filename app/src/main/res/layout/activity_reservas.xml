<!--                        android:layout_marginStart="12dp"-->
<!--                        android:layout_width="wrap_content"-->
<!--                        android:layout_height="wrap_content">-->

<!--                        <TextView-->
<!--                            android:id="@+id/txtNombre"-->
<!--                            android:text="Nombre"-->
