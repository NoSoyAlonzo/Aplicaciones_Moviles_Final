<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_app"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.utils.widget.MotionLabel
        android:id="@+id/titulo"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:text="Registro Usuario"
        android:textSize="27dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/nombre_registro"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Nombre Completo"
        android:textSize="20sp"
        android:layout_marginTop="70dp"
        app:layout_constraintTop_toBottomOf="@+id/titulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />
    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/correo_electronico"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Correo Electronico"
        android:textSize="20sp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@+id/nombre_registro"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />
    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/numero_celular"
        android:layout_width="1dp"
        android:layout_height="1dp"/>

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/fecha_nacimiento"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Fecha Nacimiento"
        android:textSize="20sp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@+id/correo_electronico"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />
    

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/Registrar"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Registrar Usuario"
        android:layout_marginTop="50dp"
        app:layout_constraintTop_toBottomOf="@+id/fecha_nacimiento"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        />
</androidx.constraintlayout.widget.ConstraintLayout>