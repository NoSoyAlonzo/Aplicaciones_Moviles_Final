<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    >

    <androidx.constraintlayout.utils.widget.MotionLabel
        android:id="@+id/titulo"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:text="Registro Usuario"
        android:textSize="27dp"
        android:textColor="@color/black"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"

        />

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/nombre_registro"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:hint="nombre completo"
        android:textSize="16sp"
        android:layout_marginTop="70dp"
        app:layout_constraintTop_toBottomOf="@+id/titulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />
    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/correo_electronico"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:hint="correo electronico"
        android:textSize="16sp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@+id/nombre_registro"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />
    <EditText
        android:id="@+id/numero_celular"
        android:layout_width="150dp"
        android:layout_height="49dp"
        android:hint="numero de celular"
        android:textSize="15sp"
        android:layout_marginStart="210dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintStart_toEndOf="@+id/fecha_nacimiento"
        app:layout_constraintTop_toTopOf="@id/fecha_nacimiento"
        />
